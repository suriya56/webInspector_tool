{
  "name": "ai-ui-editor-bridge",
  "displayName": "AI UI Editor Bridge",
  "description": "Apply AI-generated code edits from browser inspections directly in VS Code",
  "version": "0.0.1",
  "publisher": "ai-ui-editor-bridge",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ai-ui-editor-bridge.connect",
        "title": "AI UI Editor: Connect to Bridge"
      },
      {
        "command": "ai-ui-editor-bridge.disconnect",
        "title": "AI UI Editor: Disconnect from Bridge"
      },
      {
        "command": "ai-ui-editor-bridge.openChat",
        "title": "AI UI Editor: Open Chat Panel"
      },
      {
        "command": "ai-ui-editor-bridge.insertContext",
        "title": "AI UI Editor: Insert Context into Chat"
      }
    ],
    "configuration": {
      "title": "AI UI Editor Bridge",
      "properties": {
        "aiUiEditorBridge.serverUrl": {
          "type": "string",
          "default": "ws://localhost:8000/ws/ide",
          "description": "WebSocket URL for the FastAPI Bridge server"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "typescript": "^5.3.2"
  }
}
