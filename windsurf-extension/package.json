{
  "name": "ai-ui-editor-bridge-windsurf",
  "displayName": "AI UI Editor Bridge for Windsurf",
  "description": "Send browser UI context to Windsurf's Cascade AI chat",
  "version": "0.0.1",
  "publisher": "ai-ui-editor-bridge",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ai-ui-editor-bridge-windsurf.connect",
        "title": "AI UI Bridge (Windsurf): Connect"
      },
      {
        "command": "ai-ui-editor-bridge-windsurf.disconnect",
        "title": "AI UI Bridge (Windsurf): Disconnect"
      },
      {
        "command": "ai-ui-editor-bridge-windsurf.openCascade",
        "title": "AI UI Bridge (Windsurf): Open Cascade Chat"
      }
    ],
    "configuration": {
      "title": "AI UI Editor Bridge for Windsurf",
      "properties": {
        "aiUiEditorBridgeWindsurf.serverUrl": {
          "type": "string",
          "default": "ws://localhost:8000/ws/windsurf",
          "description": "WebSocket URL for the FastAPI Bridge server"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "typescript": "^5.3.2"
  }
}
